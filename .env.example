# Migratrix environment template.
# The installer copies this to .env (if .env is missing) and then fills in
# AGENT_HOST and MIGRATRIX_API_KEY for you.

# Application Configuration
APP_NAME=Migratrix
APP_VERSION=1.0.0

# Logging Configuration
LOGGING_LEVEL=Information

# Security Configuration
CORS_ORIGINS=https://app.migratrix.com,http://app.migratrix.com

# API Configuration
API_BASE_URL=https://app.migratrix.com/api

# SSL/TLS Configuration
SSL_ENABLED=true
FORCE_HTTPS=false

# Rate Limiting
API_RATE_LIMIT=10
WEB_RATE_LIMIT=30

# Health Check Configuration
HEALTH_CHECK_TIMEOUT=30
HEALTH_CHECK_RETRIES=3

# Docker Configuration
COMPOSE_PROJECT_NAME=migratrix
REGISTRY=ghcr.io/migratrix/
TAG=latest

# Published ports (host side)
AGENT_PORT=4002
HTTPS_PORT=443
DASHBOARD_PORT=8080

# Hostname Traefik serves the agent on (set by the installer via --host)
AGENT_HOST=agent.localhost

# Agent API Key — generate from Account Settings → API Key (set by the installer via --api-key)
MIGRATRIX_API_KEY=

ASPNETCORE_ENVIRONMENT=Production
